# Copy these into Dokploy → Compose service → Environment

# --- Database ---
POSTGRES_USER=medusa
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=medusa

# --- Secrets (generate with: openssl rand -hex 32) ---
JWT_SECRET=change-me-jwt-secret
COOKIE_SECRET=change-me-cookie-secret

# --- Domains (replace with your real domains) ---
MEDUSA_BACKEND_URL=https://api.yourdomain.com
STORE_FRONT_URL=https://yourdomain.com
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.yourdomain.com

# CORS — comma-separated, no spaces
STORE_CORS=https://yourdomain.com
ADMIN_CORS=https://api.yourdomain.com
AUTH_CORS=https://yourdomain.com,https://api.yourdomain.com

# --- Storefront (set AFTER creating publishable key in Medusa Admin) ---
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_your_publishable_key
NEXT_PUBLIC_DEFAULT_REGION=id

# --- Integrations (optional) ---
RAJAONGKIR_API_KEY=
RAJAONGKIR_ORIGIN_ID=
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
XENDIT_WEBHOOK_URL=https://api.yourdomain.com/hooks/payment/xendit_xendit
XENDIT_INVOICE_DURATION_SECONDS=86400
